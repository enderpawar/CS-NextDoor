{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "outDir": "dist/electron",
    "rootDir": "electron",
    "strict": true,
    "allowJs": false,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true
  },
  "include": ["electron"],
  "exclude": ["node_modules", "src", "dist", "backend"]
}
